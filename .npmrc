# @vercel/analytics declares an optional peer on @sveltejs/kit, and npm 11
# resolves optional peers eagerly: it pulls in @sveltejs/vite-plugin-svelte,
# which demands vite@8 while vitest here is on vite@7, and the install fails.
# Karalyr is a Next.js app — the SvelteKit branch is never used.
#
# Set in the file rather than passed as a flag so Vercel's build resolves the
# same way a local install does.
legacy-peer-deps=true

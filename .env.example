# libSQL connection. Local file for dev; a Turso URL (libsql://...) in production.
DATABASE_URL=file:./data/karalyr.db
# Only needed for Turso.
DATABASE_AUTH_TOKEN=

# Token that unlocks /admin. Set something long and random in production.
ADMIN_TOKEN=change-me

# Proof-of-work difficulty in leading zero bits of sha256(prefix + nonce).
# 19 ≈ 1-2 seconds of client work. Raise to slow abusive publishers.
POW_DIFFICULTY=19
# Secret used to HMAC-sign challenges so verification is stateless.
POW_SECRET=change-me-too

# Salt mixed into sha256(ip|ua|salt) fingerprints so raw IPs are never stored.
FINGERPRINT_SALT=change-me-three

# Upstream LRCLIB instance used for lazy imports.
LRCLIB_BASE_URL=https://lrclib.net
